{
  "name": "kimi-copilot-presets",
  "displayName": "Kimi for Copilot Chat",
  "description": "Use Kimi and Moonshot models from the Copilot Chat model picker with BYOK, thinking, vision, and agent tools.",
  "icon": "resources/icon.png",
  "version": "0.0.2",
  "publisher": "ivanray",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucatotem/Kimi-Extension"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChatProvider:kimi",
    "onCommand:kimi-copilot.setApiKey",
    "onCommand:kimi-copilot.getApiKey",
    "onCommand:kimi-copilot.clearApiKey",
    "onCommand:kimi-copilot.openSettings",
    "onCommand:kimi-copilot.showLogs",
    "onCommand:kimi-copilot.openRequestDumpsFolder",
    "onCommand:kimi-copilot.refreshModels"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "kimi",
        "displayName": "Kimi",
        "managementCommand": "kimi-copilot.openSettings"
      }
    ],
    "commands": [
      {
        "command": "kimi-copilot.setApiKey",
        "title": "Kimi: Set API Key"
      },
      {
        "command": "kimi-copilot.getApiKey",
        "title": "Kimi: Open API Keys"
      },
      {
        "command": "kimi-copilot.clearApiKey",
        "title": "Kimi: Clear API Key"
      },
      {
        "command": "kimi-copilot.openSettings",
        "title": "Kimi: Open Settings"
      },
      {
        "command": "kimi-copilot.showLogs",
        "title": "Kimi: Show Logs"
      },
      {
        "command": "kimi-copilot.openRequestDumpsFolder",
        "title": "Kimi: Open Request Dumps Folder"
      },
      {
        "command": "kimi-copilot.refreshModels",
        "title": "Kimi: Refresh Models"
      }
    ],
    "configuration": {
      "title": "Kimi for Copilot Chat",
      "properties": {
        "kimi-copilot.baseUrl": {
          "type": "string",
          "default": "https://api.moonshot.ai/v1",
          "description": "Base URL for the Kimi/Moonshot OpenAI-compatible API."
        },
        "kimi-copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Max output tokens to request. 0 uses the API default."
        },
        "kimi-copilot.enableModelDiscovery": {
          "type": "boolean",
          "default": true,
          "description": "Fetch /v1/models when an API key is configured and merge discovered models into the picker."
        },
        "kimi-copilot.modelIdOverrides": {
          "type": "object",
          "default": {
            "kimi-k2.7-code": "kimi-k2.7-code",
            "kimi-k2.6": "kimi-k2.6",
            "kimi-k2.5": "kimi-k2.5",
            "moonshot-v1-8k": "moonshot-v1-8k",
            "moonshot-v1-32k": "moonshot-v1-32k",
            "moonshot-v1-128k": "moonshot-v1-128k",
            "moonshot-v1-8k-vision-preview": "moonshot-v1-8k-vision-preview",
            "moonshot-v1-32k-vision-preview": "moonshot-v1-32k-vision-preview",
            "moonshot-v1-128k-vision-preview": "moonshot-v1-128k-vision-preview"
          },
          "description": "API model IDs to send for each Kimi picker entry. Change this for compatible proxies with different model names.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "kimi-copilot.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumItemLabels": [
            "Minimal",
            "Metadata",
            "Verbose"
          ],
          "markdownEnumDescriptions": [
            "Only show warnings and errors.",
            "Log request metadata without prompt text.",
            "Write full request dumps under extension global storage. Avoid this mode when prompts contain sensitive data."
          ],
          "markdownDescription": "Controls diagnostic logging in the Kimi output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0"
  }
}
